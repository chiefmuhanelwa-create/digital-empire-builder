{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tanstack-start-app",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "workers_dev": false,
  "routes": [
    { "pattern": "chkplt.com/*", "zone_name": "chkplt.com" }
  ],
  "triggers": {
    // Daily 04:10 UTC (06:10 SAST) — reconcile ZAR charges to the live USD→ZAR rate.
    "crons": ["10 4 * * *"]
  }
}
