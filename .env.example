# ================================================================
# CHKPLT DIGITAL EMPIRE BUILDER — ENVIRONMENT VARIABLES
# ================================================================
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to git. .env.example is safe to commit.
# Run: cp .env.example .env
# ================================================================

# ── SUPABASE (database + auth + storage) ────────────────────────
# Project URL and anon key — public, safe for client-side use
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
VITE_SUPABASE_PROJECT_ID=your-project-id

# Service role key — PRIVATE, server-only, NEVER expose to client
# Required for: admin server functions, email queue worker, product grants
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── PAYSTACK (SA/AFRICA PAYMENTS — ZAR) ─────────────────────────
# For ZAR transactions — South Africa and African market
# Test keys: sk_test_... / pk_test_... | Live keys: sk_live_... / pk_live_...
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret
# Set webhook URL in Paystack Dashboard → Settings → Webhooks → https://chkplt.com/api/public/paystack-webhook
VITE_PAYSTACK_PUBLIC_KEY=pk_live_...

# ── STRIPE (INTERNATIONAL PAYMENTS — USD / GBP / EUR / AUD) ─────
# For non-ZAR transactions — global and international market
# Test keys: sk_test_... / pk_test_... | Live keys: sk_live_... / pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Set webhook URL in Stripe Dashboard → Developers → Webhooks → https://chkplt.com/api/public/stripe-webhook
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── CLOUDFLARE TURNSTILE (CAPTCHA / BOT PROTECTION) ─────────────
# Required on: /apply, /signup, /login, /contact, checkout
# Get keys at: https://dash.cloudflare.com → Turnstile → Add site
VITE_TURNSTILE_SITE_KEY=0x...
TURNSTILE_SECRET_KEY=0x...

# ── RESEND (TRANSACTIONAL EMAIL) ─────────────────────────────────
# Powers: magic-link login, signup confirmation, order receipts, password reset
# Sign up at resend.com → add domain notify.chkplt.com → copy API key
# Add DNS records Resend provides to Cloudflare to verify notify.chkplt.com
RESEND_API_KEY=re_...

# Auth hook secret — set the SAME value in:
#   1. This file (for local dev)
#   2. Cloudflare Workers secrets: bunx wrangler secret put SUPABASE_AUTH_HOOK_SECRET
#   3. Supabase dashboard → Authentication → Hooks → Send Email → HTTP secret
SUPABASE_AUTH_HOOK_SECRET=your-random-secret-here

# ── MAILERLITE (MARKETING EMAIL AUTOMATION) ──────────────────────
# Powers: welcome sequences, lead magnet delivery, ICP 1 upgrade nurture, broadcasts
# Get API key: MailerLite → Integrations → API
MAILERLITE_API_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiJ9...

# Group IDs — get from MailerLite → Subscribers → Groups
MAILERLITE_GROUP_ID_CALLED_EXPERT=
MAILERLITE_GROUP_ID_FREE_BLUEPRINT=          # Called Expert Blueprint (POSSESS PDF)
MAILERLITE_GROUP_ID_FREE_11TH_HOUR=          # The 11th Hour Playbook (Matthew 20)
MAILERLITE_GROUP_ID_FREE_RIGHT_SIDE=         # The Right Side Assessment (John 21)
MAILERLITE_GROUP_ID_FREE_4HR_WINDOW=         # The 4-Hour Window Starter System
MAILERLITE_GROUP_ID_FREE_KNOWLEDGE_AUDIT=    # Your Knowledge Audit
MAILERLITE_GROUP_ID_BUYERS=                  # All paying customers

# ── APPLICATION ───────────────────────────────────────────────────
VITE_APP_URL=https://chkplt.com
NODE_ENV=development
